{
  "name": "cricket-manage",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "next build --webpack",
    "build:cf": "npx @opennextjs/cloudflare build && node -e \"const fs=require('fs'); const path=require('path'); const copyDir=(s,d)=>{if(!fs.existsSync(d))fs.mkdirSync(d);fs.readdirSync(s).forEach(f=>{const ss=path.join(s,f);const dd=path.join(d,f);if(fs.statSync(ss).isDirectory())copyDir(ss,dd);else fs.copyFileSync(ss,dd)})}; copyDir('.open-next/assets','.open-next'); fs.renameSync('.open-next/worker.js','.open-next/_worker.js')\"",
    "dev": "next dev",
    "start": "next start",
    "lint": "next lint",
    "preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "upload": "opennextjs-cloudflare build && opennextjs-cloudflare upload",
    "cf-typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts"
  },
  "dependencies": {
    "@opennextjs/cloudflare": "^1.19.9",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.105.4",
    "browser-image-compression": "^2.0.2",
    "framer-motion": "^11.2.6",
    "next": "^16.2.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-icons": "^5.2.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260511.1",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "autoprefixer": "^10.4.19",
    "esbuild": "^0.28.0",
    "eslint": "^9",
    "eslint-config-next": "^16.2.6",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3",
    "typescript": "^5",
    "wrangler": "^4.90.1"
  }
}
